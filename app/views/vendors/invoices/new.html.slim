- content_for :header_content do
  h2.page-header
    = class_icon "vendor", icon_options: "medium"
    span.text
      = link_to vendors_path, class: "breadcrumb primary" do
        span.link-text
          '  Vendors
      '
      = link_to vendor_path(@vendor), class: "breadcrumb" do
        span.link-text
          = @vendor.name
      '
      = link_to vendor_path(@vendor, anchor: "invoices"), class: "breadcrumb" do
        span.link-text Invoices
      '
      span.breadcrumb
        '
        ' New

== render partial: 'form', locals: { back_path: vendor_invoices_path(@vendor) }
