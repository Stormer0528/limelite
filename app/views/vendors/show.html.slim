= content_for :page_title
  '&nbsp; :: Vendors > #{@vendor.name}

- content_for :head do
  = javascript_pack_tag 'render_vendor_show', defer: true, charset: 'utf-8'

  css:
    :root main.container {
      width: 85%;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
      height: calc(100vh - 70px);
    }

    @media (min-width: 685px) {
      :root main.container {
        width: 95%;
      }
    }

    @media (max-width: 599.95px) {
      :root main.container {
        width: 90%;
      }
    }

    #vendor-show-view {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
    }

    @media only screen and (max-height: 555px){
      body > main.container{
        margin: 0;
        width: 100vw !important;
        height: calc(100vh - 40px);
      }

      body > main.container #entries_index  {
       display: contents;
      }
    }

/ Vendor#show
/ Note: Similar to Customer#show

- content_for :header_content do
  h2.page-header
    = class_icon "vendor", icon_options: "medium"
    span.text
      = link_to vendors_path, class: "breadcrumb primary" do
        span.link-text
          '  Vendors
      '
      span.breadcrumb = @vendor.name

#vendor-show-view data-fiscal-year="#{@fiscal_year.year}"
